# ==========================================
# China PD Monthly Report - .gitignore
# ==========================================
# 排除敏感数据、API key、临时文件
# 不要修改本文件除非你清楚后果
# ==========================================

# ---- API key & 凭证(绝对不能上 public repo)----
claude_api_key.txt
*.key
*.pem
.env
.env.*

# ---- 数据源 xlsx(内部 PD 数据,不公开)----
China PD updates *.xlsx
Project list.xlsx
Summers_Monthly_PD_Table*.xlsx
*.xlsm

# ---- HTML 备份版本(只保留最新)----
*_prev.html

# ---- Python 缓存 ----
__pycache__/
*.pyc
*.pyo
*.pyd

# ---- 系统文件 ----
.DS_Store
Thumbs.db
desktop.ini

# ---- 编辑器临时文件 ----
.~lock.*
~$*
*.swp
*.swo

# ---- IDE 配置 ----
.vscode/
.idea/

# ---- 其它(以后想排除的随手加这里)----
